# 记忆宫殿 LLM 配置模板
# 复制此文件为 .env 并填入实际配置
# 注意：.env 包含敏感信息，不应提交到 Git

# Vault 路径（请根据你的实际路径修改）
OBSIDIAN_VAULT=<你的 Vault 路径，例如：C:/Users/your-name/mind-palace-vault>

# LLM API 配置
# 默认使用 Anthropic 官方 API（兼容 Claude 系列模型）
LLM_API_KEY=<你的 API Key>
LLM_MODEL=claude-sonnet-4-5-20251001
LLM_API_BASE_URL=https://api.anthropic.com

# 如果使用通义千问（DashScope Anthropic 兼容接口），修改为：
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen3.5-plus
# LLM_API_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# 炼金术 Agent 配置
ALCHEMY_USE_LLM=true  # 设置为 true 启用 LLM 日记生成
