# 记忆宫殿环境变量示例
# 复制为 .env 并填入真实值

# ==================== Obsidian 路径 ====================

# Obsidian Vault 绝对路径（必填）
# Windows: OBSIDIAN_VAULT="C:/Users/yourname/Documents/Obsidian Vault"
# Mac: OBSIDIAN_VAULT="/Users/yourname/Documents/Obsidian Vault"
# Linux: OBSIDIAN_VAULT="/home/yourname/Obsidian Vault"
OBSIDIAN_VAULT=

# ==================== LLM 配置 ====================

# 选择 LLM 提供商：google, anthropic, openai, custom
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ==================== 其他配置 ====================

# 日志级别
LOG_LEVEL=info

# 时区
TZ=Asia/Shanghai
